# Get OKX credentials:
# 1. Create or log in to your OKX developer account:
#    https://web3.okx.com/build/dev-portal
# 2. Generate an API key in the project you want to use:
#    https://web3.okx.com/onchainos/dev-docs/home/developer-portal
OKX_API_KEY="your-okx-api-key"
OKX_SECRET_KEY="your-okx-secret-key"
OKX_PASSPHRASE="your-okx-passphrase"

# Get Primus zkTLS credentials:
# 1. Create a project in Primus Developer Hub:
#    https://dev.primuslabs.xyz/
# 2. Refer to the zkTLS overview/install docs if needed:
#    https://docs.primuslabs.xyz/data-verification/zk-tls-sdk/overview/
#    https://docs.primuslabs.xyz/data-verification/zk-tls-sdk/install/
ZKTLS_APP_ID="your-primus-app-id"
ZKTLS_APP_SECRET="your-primus-app-secret"

# Optional overrides
# DEMO_CHAIN_INDEX="1"
# DEMO_TOKEN_ADDRESS="0xeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"
# DEMO_TIMEOUT_MS="120000"
# DEMO_SEARCH_CHAINS="501"
# DEMO_SEARCH_QUERY="BONK"
# DEMO_BASIC_INFO_CHAIN_INDEX="501"
# DEMO_BASIC_INFO_TOKEN_ADDRESS="So11111111111111111111111111111111111111112"
# DEMO_WALLET_ADDRESS="0x28C6c06298d514Db089934071355E5743bf21d60"
# DEMO_WALLET_CHAIN_INDEX="1"
# DEMO_WALLET_TOKEN_ADDRESS="0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48"
# DEMO_WALLET_TOTAL_ADDRESS="0x28C6c06298d514Db089934071355E5743bf21d60"
# DEMO_WALLET_TOTAL_CHAINS="1"
# DEMO_WALLET_TOTAL_ASSET_TYPE="0"
# DEMO_GAS_CHAIN_INDEX="1"
# DEMO_LIQUIDITY_CHAIN_INDEX="1"
# DEMO_SWAP_CHAIN_INDEX="1"
# DEMO_SWAP_AMOUNT="100000000"
# DEMO_SWAP_MODE="exactIn"
# DEMO_SWAP_FROM_TOKEN_ADDRESS="0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48"
# DEMO_SWAP_TO_TOKEN_ADDRESS="0xdac17f958d2ee523a2206206994597c13d831ec7"
